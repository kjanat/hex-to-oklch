{
	"name": "hex-to-oklch",
	"version": "0.1.0",
	"description": "Tiny, zero-dependency hex-to-OKLCH color converter",
	"keywords": [
		"hex",
		"oklch",
		"oklab",
		"color",
		"css",
		"convert"
	],
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"bun": "./src/index.ts",
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		}
	},
	"bin": {
		"hex-to-oklch": "./dist/hex-to-oklch.mjs"
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"bd": "tsdown",
		"fmt": "dprint fmt",
		"prepublishOnly": "bun --bun bd",
		"test": "bun test",
		"typecheck": "tsgo --noEmit"
	},
	"devDependencies": {
		"@types/bun": "^1.3.9",
		"@typescript/native-preview": "^7.0.0-dev.20260226.1",
		"dprint": "^0.52.0",
		"tsdown": "^0.21.0-beta.2"
	}
}
